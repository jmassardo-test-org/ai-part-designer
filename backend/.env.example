# AssemblematicAI - Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application
# =============================================================================
APP_NAME=assemblematic-ai
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/assemblematic_ai
DATABASE_POOL_SIZE=5
DATABASE_POOL_OVERFLOW=10

# =============================================================================
# Redis (Cache & Message Broker)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Object Storage (MinIO - S3-compatible, cloud-agnostic)
# =============================================================================
STORAGE_BACKEND=minio
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=assemblematic-ai-dev
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# =============================================================================
# AI Provider Configuration
# =============================================================================
# Choose your AI provider: openai, ollama, anthropic, or azure
AI_PROVIDER=openai

# -----------------------------------------------------------------------------
# OpenAI (default)
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
# OPENAI_MODEL=gpt-4-turbo-preview

# -----------------------------------------------------------------------------
# Ollama (FREE - for local development!)
# -----------------------------------------------------------------------------
# 1. Install Ollama: https://ollama.ai
# 2. Pull a model: ollama pull llama3.2
# 3. Start server: ollama serve
# 4. Set AI_PROVIDER=ollama above
#
# Recommended models:
#   - llama3.2 (fast, general purpose)
#   - codellama:13b (good for code/structured output)
#   - mistral (good reasoning)
#   - mixtral (best quality, slower)
#
# AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# -----------------------------------------------------------------------------
# Anthropic Claude
# -----------------------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/
# AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
# AI_PROVIDER=azure
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# -----------------------------------------------------------------------------
# General AI Settings
# -----------------------------------------------------------------------------
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# =============================================================================
# Authentication (JWT)
# =============================================================================
JWT_SECRET_KEY=jwt-secret-key-for-development-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_GENERATION_PER_HOUR=20

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# =============================================================================
# Feature Flags (Development)
# =============================================================================
ENABLE_API_DOCS=true
ENABLE_DEBUG_ENDPOINTS=true
