# AssemblematicAI - Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application
# =============================================================================
APP_NAME=assemblematic-ai
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/assemblematic_ai
DATABASE_POOL_SIZE=5
DATABASE_POOL_OVERFLOW=10

# =============================================================================
# Redis (Cache & Message Broker)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Object Storage (MinIO - S3-compatible, cloud-agnostic)
# =============================================================================
STORAGE_BACKEND=minio
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=assemblematic-ai-dev
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# =============================================================================
# AI Provider Configuration (Claude / Anthropic)
# =============================================================================
# Claude is the only supported AI provider
AI_PROVIDER=anthropic

# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# General AI Settings
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# =============================================================================
# Authentication (JWT)
# =============================================================================
JWT_SECRET_KEY=jwt-secret-key-for-development-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Frontend URL (for email links, OAuth redirects)
# =============================================================================
# Development: http://localhost:5173
# Production: https://assemblematic.ai
FRONTEND_URL=http://localhost:5173
OAUTH_REDIRECT_BASE=http://localhost:5173

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_GENERATION_PER_HOUR=20

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# =============================================================================
# Feature Flags (Development)
# =============================================================================
ENABLE_API_DOCS=true
ENABLE_DEBUG_ENDPOINTS=true
