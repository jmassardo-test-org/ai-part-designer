# AI Part Designer - Root Environment Configuration
# Copy this file to .env for docker-compose to use

# =============================================================================
# AI Provider Configuration
# =============================================================================
# Choose your AI provider: openai, ollama, anthropic, or azure
AI_PROVIDER=openai

# OpenAI (requires API key)
OPENAI_API_KEY=sk-your-openai-api-key

# Ollama (FREE - for local development!)
# 1. Install: https://ollama.ai
# 2. Pull model: ollama pull llama3.2
# 3. Change AI_PROVIDER=ollama above
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2

# =============================================================================
# Optional: Override Default Ports
# =============================================================================
# API_PORT=8000
# FRONTEND_PORT=5173
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001

# =============================================================================
# Optional: Production Secrets (change these in production!)
# =============================================================================
# SECRET_KEY=change-this-in-production
# JWT_SECRET_KEY=change-this-in-production
# POSTGRES_PASSWORD=change-this-in-production
