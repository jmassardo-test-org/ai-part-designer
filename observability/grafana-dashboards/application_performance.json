{
  "dashboard": {
    "title": "Part Designer - API Performance",
    "uid": "pd_api_perf_72059",
    "tags": [
      "ai-part-designer",
      "auto-generated"
    ],
    "timezone": "browser",
    "editable": true,
    "graphTooltip": 1,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": [
        "10s",
        "30s",
        "1m",
        "5m"
      ]
    },
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Total Request Throughput",
        "gridPos": {
          "h": 5,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"part-designer-api\"}[2m]))",
            "refId": "throughput",
            "interval": "",
            "legendFormat": ""
          }
        ],
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ]
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "API Latency (95th Percentile)",
        "gridPos": {
          "h": 5,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"part-designer-api\"}[5m])) by (le))",
            "refId": "p95",
            "interval": "",
            "legendFormat": ""
          }
        ],
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 0.5,
                  "color": "yellow"
                },
                {
                  "value": 1.5,
                  "color": "red"
                }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ]
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Server Error Percentage",
        "gridPos": {
          "h": 5,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "100 * (sum(rate(http_requests_total{status=~\"5..\",job=\"part-designer-api\"}[5m])) / sum(rate(http_requests_total{job=\"part-designer-api\"}[5m])))",
            "refId": "errors",
            "interval": "",
            "legendFormat": ""
          }
        ],
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 1,
                  "color": "yellow"
                },
                {
                  "value": 3,
                  "color": "red"
                }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": [
              "lastNotNull"
            ]
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area"
        }
      },
